---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const games = await getCollection('games');
  return games.map((game) => ({
    params: { slug: game.id },
    props: { game },
  }));
}

const { game } = Astro.props;
const { Content } = await render(game);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const buildHref = game.data.buildPath
  ? `${base}/${game.data.buildPath.replace(/^\//, "")}/index.html`
  : null;
---

<Layout title={`${game.data.title} — Beckham Yeoh`} description={game.data.tagline}>
  <a class="back" href={base || "/"}>← All games</a>
  <header class="game-header">
    <h1>{game.data.title}</h1>
    <p class="lede">{game.data.tagline}</p>
    <div class="meta">
      {game.data.year && <span>{game.data.year}</span>}
      {game.data.tech.length > 0 && <span>{game.data.tech.join(" · ")}</span>}
      {game.data.repo && (
        <a href={game.data.repo} target="_blank" rel="noopener">Source ↗</a>
      )}
    </div>
  </header>

  {game.data.playable && buildHref ? (
    <div class="webgl-wrap" data-webgl>
      <iframe
        src={buildHref}
        title={`${game.data.title} — WebGL`}
        allow="autoplay; fullscreen; gamepad"
        allowfullscreen
        loading="lazy"
      ></iframe>
      <button class="fs-btn" type="button" data-fs aria-label="Toggle fullscreen">
        ⛶ Fullscreen
      </button>
    </div>
  ) : (
    <div class="not-playable">
      <p>
        This game isn't playable in the browser yet. A WebGL build will be
        added soon.
      </p>
    </div>
  )}

  <article class="prose">
    <Content />
  </article>
</Layout>

<script>
  const wrap = document.querySelector<HTMLElement>('[data-webgl]');
  const btn = document.querySelector<HTMLButtonElement>('[data-fs]');
  if (wrap && btn) {
    btn.addEventListener('click', async () => {
      if (document.fullscreenElement) {
        await document.exitFullscreen();
      } else {
        await wrap.requestFullscreen().catch(() => {});
      }
    });
    document.addEventListener('fullscreenchange', () => {
      btn.textContent = document.fullscreenElement ? '⛶ Exit fullscreen' : '⛶ Fullscreen';
    });
  }
</script>

<style>
  .back { display: inline-block; margin-bottom: 1rem; color: var(--text-muted); }
  .game-header { margin-bottom: 1.5rem; }
  .meta { display: flex; gap: 1rem; color: var(--text-muted); font-size: 0.9rem; margin-top: 0.5rem; }
  .webgl-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 2rem;
  }
  .webgl-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .fs-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    z-index: 2;
    background: rgba(14, 15, 19, 0.7);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.35rem 0.6rem;
    font-size: 0.85rem;
    cursor: pointer;
    backdrop-filter: blur(4px);
  }
  .fs-btn:hover { background: rgba(14, 15, 19, 0.9); border-color: var(--accent); }
  .webgl-wrap:fullscreen { aspect-ratio: auto; height: 100vh; border-radius: 0; }
  .webgl-wrap:fullscreen iframe { position: absolute; inset: 0; }
  .not-playable {
    background: var(--bg-elevated);
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }
  .prose :global(h2) { margin-top: 1.5rem; }
  .prose :global(p) { color: var(--text); }
  .prose :global(ul) { padding-left: 1.25rem; }
</style>
