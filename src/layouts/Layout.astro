---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Game portfolio by Beckham Yeoh" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href={base || "/"} class="site-title">Beckham Yeoh — Games</a>
      <nav>
        <a href={base || "/"}>Home</a>
        <a href="https://github.com/beckhamyeoh" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Built with Astro · <a href="https://github.com/beckhamyeoh/GamePortfolio">source</a></p>
    </footer>
    <style is:global>
      :root {
        --bg: #0e0f13;
        --bg-elevated: #16181f;
        --border: #262932;
        --text: #e7e9ee;
        --text-muted: #9aa0ab;
        --accent: #7aa2ff;
        --accent-hover: #a4bfff;
        --radius: 10px;
        --max-width: 1100px;
        font-family:
          ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue",
          Arial, sans-serif;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        line-height: 1.5;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { color: var(--accent-hover); }
      main { flex: 1; max-width: var(--max-width); width: 100%; margin: 0 auto; padding: 2rem 1.25rem; }
      .site-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: var(--max-width);
        width: 100%;
        margin: 0 auto;
        padding: 1.25rem;
        border-bottom: 1px solid var(--border);
      }
      .site-title { color: var(--text); font-weight: 600; }
      .site-header nav a { margin-left: 1rem; color: var(--text-muted); }
      .site-header nav a:hover { color: var(--text); }
      .site-footer {
        max-width: var(--max-width);
        width: 100%;
        margin: 0 auto;
        padding: 1.5rem 1.25rem;
        border-top: 1px solid var(--border);
        color: var(--text-muted);
        font-size: 0.9rem;
      }
      h1, h2, h3 { line-height: 1.2; }
      h1 { font-size: clamp(1.8rem, 4vw, 2.5rem); margin: 0 0 0.5rem; }
      .lede { color: var(--text-muted); font-size: 1.05rem; max-width: 60ch; }
    </style>
  </body>
</html>
